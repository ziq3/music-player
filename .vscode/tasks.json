{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build",
      "type": "shell",
      "command": "cmake --build ${workspaceFolder}/build",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Run Application",
      "type": "shell",
      "command": "cmake --build ${workspaceFolder}/build && ${workspaceFolder}/build/untitled1",
      "group": {
        "kind": "test",
        "isDefault": true
      }
    }
  ]
}
